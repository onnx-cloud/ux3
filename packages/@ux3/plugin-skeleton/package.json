{
  "name": "@ux3/plugin-skeleton",
  "version": "0.1.0",
  "description": "Scaffolding plugin for UX3 - generates projects, views, services, and other artifacts from templates",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ux3/ux3": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^1.0.0"
  },
  "keywords": ["ux3", "plugin", "skeleton", "scaffolding", "templates"]
}
