{
  "name": "@ux3/test-harness",
  "version": "1.0.0",
  "description": "Testing utilities and fixtures for UX3 Framework - FSM testing, mock services, view testing helpers",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./fsm": "./dist/fsm.js",
    "./services": "./dist/services.js",
    "./views": "./dist/views.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest"
  },
  "dependencies": {
    "@ux3/ux3": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/ui": "^1.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "ux3",
    "testing",
    "fsm",
    "fixtures",
    "mock",
    "spy",
    "harness"
  ],
  "author": "UX3 Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ux3/ux3.git",
    "directory": "packages/@ux3/test-harness"
  }
}
