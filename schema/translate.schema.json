{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ux3://schemas/translate.schema.json",
  "title": "UX3 Translator Config Schema",
  "type": "object",
  "required": ["endpoint", "model", "apiKey", "locales"],
  "additionalProperties": false,
  "properties": {
    "endpoint": {
      "type": "string",
      "format": "uri",
      "description": "OpenAI-compatible chat completions endpoint URL"
    },
    "model": {
      "type": "string",
      "minLength": 1,
      "description": "Model identifier (e.g. openai/gpt-oss-120b)"
    },
    "apiKey": {
      "type": "string",
      "minLength": 1,
      "description": "Bearer token for the endpoint (use {{ env.KEY }} reference, never commit plain secrets)"
    },
    "defaultLocale": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(-[A-Z]{2,})?$",
      "default": "en",
      "description": "BCP-47 locale tag for the source language"
    },
    "locales": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z]{2,3}(-[A-Z]{2,})?$"
      },
      "description": "Supported target locale tags"
    }
  }
}
