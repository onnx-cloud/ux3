{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agentic Pattern Definition",
  "description": "Schema for agentic pattern YAML definitions used by plugin-agentic.",
  "type": "object",
  "required": ["id", "initial", "states"],
  "properties": {
    "id": { "type": "string" },
    "description": { "type": "string" },
    "initial": { "type": "string" },
    "states": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["atomic", "compound", "parallel", "final"] },
          "template": { "type": "string" },
          "context": { "type": "object", "additionalProperties": true },
          "invoke": {
            "type": "object",
            "properties": {
              "src": { "type": "string" },
              "maxRetries": { "type": "integer", "minimum": 0 },
              "retryDelay": { "type": "number", "minimum": 0 }
            },
            "required": ["src"],
            "additionalProperties": false
          },
          "on": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
