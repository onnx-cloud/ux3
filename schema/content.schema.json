{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Markdown Content Frontmatter",
  "description": "Schema for YAML frontmatter in Markdown files used by the content generator.",
  "type": "object",
  "properties": {
    "title": { "type": "string" },
    "date": { "type": "string", "format": "date-time" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "path": { "type": "string" },
    "route": { "type": "string" },
    "slug": { "type": "string" },
    "template": { "type": "string" },
    "layout": { "type": "string" }
  },
  "additionalProperties": true
}