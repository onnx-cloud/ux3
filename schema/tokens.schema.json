  "title": "Tokens schema",
  "type": "object",
  "properties": {
    "colors": {
      "type": "object",
      "patternProperties": {
        "^.*$": {
          "type": "object",
          "patternProperties": {
            "^.*$": { "type": "string" }
          }
        }
      }
    },
    "spacing": {
      "type": "object",
      "patternProperties": {
        "^.*$": { "type": "string" }
      }
    },
    "typography": {
      "type": "object",
      "patternProperties": {
        "^.*$": { "type": "string" }
      }
    }
  },
  "additionalProperties": true
}
