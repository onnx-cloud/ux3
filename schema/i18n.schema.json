{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "I18n schema",
  "type": "object",
  "description": "Top-level locales mapping to nested translation keys",
  "patternProperties": {
    "^[a-z]{2}(?:-[A-Z]{2})?$": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          { "type": "string" },
          { "type": "object", "additionalProperties": { "anyOf": [ { "type": "string" }, { "type": "object" } ] } }
        ]
      }
    }
  },
  "additionalProperties": false
}
