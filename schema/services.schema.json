{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Services schema",
  "type": "object",
  "required": ["services"],
  "properties": {
    "services": {
      "type": "object",
      "patternProperties": {
        "^.*$": {
          "type": "object",
          "properties": {
            "adapter": { "type": "string", "enum": ["plugin", "file", "http", "websocket", "jsonrpc", "mock" ] },
            "baseUrl": { "type": "string" },
            "url": { "type": "string" },
            "endpoint": { "type": "string" },
            "auth": {
              "type": ["object", "null"],
              "properties": {
                "type": { "type": "string" },
                "token": { "type": "string" }
              },
              "additionalProperties": true
            },
            "reconnectAttempts": { "type": "integer" },
            "reconnectInterval": { "type": "integer" },
            "caching": {
              "type": "object",
              "properties": { "enabled": { "type": "boolean" }, "ttl": { "type": "integer" } },
              "additionalProperties": false
            }
          },
          "additionalProperties": true
        }
      }
    }
  },
  "additionalProperties": false
}
