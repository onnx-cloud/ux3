{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Declarative test configuration",
  "type": "object",
  "properties": {
    "name": { "type": "string" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/step" }
    }
  },
  "required": ["steps"],
  "definitions": {
    "step": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "when": { "type": "string" }
      },
      "required": ["type"],
      "allOf": [
        { "$ref": "#/definitions/eventStep" },
        { "$ref": "#/definitions/inputStep" },
        { "$ref": "#/definitions/clickStep" },
        { "$ref": "#/definitions/waitStep" },
        { "$ref": "#/definitions/assertStep" },
        { "$ref": "#/definitions/assertStateStep" },
        { "$ref": "#/definitions/fsmStateStep" }
      ]
    },
    "eventStep": {
      "if": { "properties": { "type": { "const": "event" } } },
      "then": {
        "properties": {
          "type": { "const": "event" },
          "name": { "type": "string" },
          "payload": {},
          "machine": { "type": "string" }
        },
        "required": ["name"]
      }
    },
    "inputStep": {
      "if": { "properties": { "type": { "const": "input" } } },
      "then": {
        "properties": {
          "type": { "const": "input" },
          "selector": { "type": "string" },
          "text": { "type": "string" }
        },
        "required": ["selector", "text"]
      }
    },
    "clickStep": {
      "if": { "properties": { "type": { "const": "click" } } },
      "then": {
        "properties": {
          "type": { "const": "click" },
          "selector": { "type": "string" }
        },
        "required": ["selector"]
      }
    },
    "waitStep": {
      "if": { "properties": { "type": { "const": "wait" } } },
      "then": {
        "properties": {
          "type": { "const": "wait" },
          "condition": { "type": "string" },
          "timeout": { "type": "number" }
        }
      }
    },
    "assertStep": {
      "if": { "properties": { "type": { "const": "assert" } } },
      "then": {
        "properties": {
          "type": { "const": "assert" },
          "selector": { "type": "string" },
          "text": { "type": "string" },
          "exists": { "type": "boolean" }
        },
        "required": ["selector"]
      }
    },
    "assertStateStep": {
      "if": { "properties": { "type": { "const": "assertState" } } },
      "then": {
        "properties": {
          "type": { "const": "assertState" },
          "path": { "type": "string" },
          "equals": {},
          "machine": { "type": "string" }
        },
        "required": ["path", "equals"]
      }
    },
    "fsmStateStep": {
      "if": { "properties": { "type": { "const": "fsmState" } } },
      "then": {
        "properties": {
          "type": { "const": "fsmState" },
          "machine": { "type": "string" },
          "equals": {
            "anyOf": [ { "type": "string" }, { "type": "array" }, { "type": "object", "instanceof": "RegExp" } ]
          }
        },
        "required": ["equals"]
      }
    }
  }
}
