{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UX3 project configuration schema",
  "type": "object",
  "required": ["name", "index"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Unique application identifier (e.g. app.my.project)"
    },
    "index": {
      "type": "string",
      "minLength": 1,
      "description": "Entry-point view, relative to ux/ (e.g. widget/home.yaml)"
    },
    "domain": {
      "type": "string",
      "description": "Optional domain name for the application"
    },
    "site": {
      "type": "object",
      "description": "Site-level config for assets, head injections, and scripts. Use ux/i18n for site.title and site.description.",
      "properties": {
        "assets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["style", "script"] },
              "href": { "type": "string" },
              "src": { "type": "string" },
              "async": { "type": "boolean" },
              "defer": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        },
        "cdn": { "type": "array", "items": { "type": "string" } },
        "head": { "type": "string", "description": "Raw HTML injected into <head>" },
        "scripts": { "type": "string", "description": "Raw HTML injected before </body>" }
      },
      "not": {
        "anyOf": [
          { "required": ["title"] },
          { "required": ["description"] }
        ]
      },
      "additionalProperties": false
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "config": { "type": "object" }
        },
        "additionalProperties": false
      }
    },
    "oauth": {
      "type": "object",
      "properties": {
        "google": { "type": "object", "additionalProperties": true },
        "okta": { "type": "object", "additionalProperties": true },
        "auth0": { "type": "object", "additionalProperties": true },
        "cognito": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": true
    },
    "context": {
      "type": "object",
      "description": "Project-level FSM context values",
      "properties": {
        "@id": { "type": "string", "format": "uri" }
      },
      "required": ["@id"],
      "additionalProperties": true
    },
    "persist": {
      "type": "object",
      "description": "Persistence configuration for app and FSM context state.",
      "properties": {
        "context": {
          "type": "object",
          "properties": {
            "adapter": { "type": "string" },
            "ttl": { "type": "number", "minimum": 0 },
            "config": { "type": "object", "additionalProperties": true }
          },
          "required": ["adapter"],
          "additionalProperties": false
        },
        "plan": {
          "type": "object",
          "properties": {
            "adapter": { "type": "string" },
            "ttl": { "type": "number", "minimum": 0 },
            "config": { "type": "object", "additionalProperties": true }
          },
          "required": ["adapter"],
          "additionalProperties": false
        },
        "state": {
          "type": "object",
          "properties": {
            "adapter": { "type": "string" },
            "ttl": { "type": "number", "minimum": 0 },
            "config": { "type": "object", "additionalProperties": true }
          },
          "required": ["adapter"],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "development": {
      "type": "object",
      "properties": {
        "hot-reload": { "type": "boolean" },
        "logging": { "type": "string" },
        "inspector": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "runtime": {
      "type": "object",
      "properties": {
        "bundleKey": { "type": "string" },
        "hydrationFn": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
