{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": { 
      "@ux3/*": ["src/*", "packages/@ux3/*/src"] 
    }
  },
  "include": ["src/**/*.ts", "packages/@ux3/*/src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}