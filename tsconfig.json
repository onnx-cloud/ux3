{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "skipLibCheck": true,
    "strict": false,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": { 
      "@ux3/*": [
        "./src/*",
        "./packages/@ux3/*/src"
      ]
    }
  },
  "include": ["src/**/*.ts", "packages/@ux3/*/src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}