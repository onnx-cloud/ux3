{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "skipLibCheck": true,
    "strict": false,
    "resolveJsonModule": true,
    "noEmit": false,
    "rootDir": ".",
    "outDir": "./dist",
    "paths": { 
      "@ux3/*": [
        "./src/*",
        "./packages/@ux3/*/src"
      ],
      "@ux3/plugin-dev-tools/*": [
        "./packages/@ux3/plugin-dev-tools/src/*"
      ],
      "@ux3/plugin-i18n/*": [
        "./packages/@ux3/plugin-i18n/src/*"
      ]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/templates"]
}