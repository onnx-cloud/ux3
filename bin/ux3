#!/usr/bin/env node
import { spawnSync } from 'node:child_process';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const cliFile = path.join(__dirname, '../src/cli/cli.ts');
const cleanJsFile = path.join(__dirname, './clean-js');

const cleanResult = spawnSync(cleanJsFile, {
  stdio: 'inherit',
});

if ((cleanResult.status ?? 0) !== 0) {
  process.exit(cleanResult.status ?? 1);
}

const result = spawnSync('npx', ['tsx', cliFile, ...process.argv.slice(2)], {
  stdio: 'inherit',
});

process.exit(result.status ?? 1);
