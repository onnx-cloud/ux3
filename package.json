{
  "name": "@ux3/ux",
  "version": "0.2.1",
  "description": "Tiny declarative UI framework. batteries included.",
  "license": "MIT",
  "author": "UX3 Contributors",
  "homepage": "https://iqns.org/ux3/",
  "repository": {
    "type": "git",
    "url": "https://github.com/iqns-org/ux3.git"
  },
  "bugs": {
    "url": "https://github.com/iqns-org/ux3/issues"
  },
  "keywords": [
    "ui",
    "framework",
    "fsm",
    "tate-machine",
    "accessibility",
    "wcag",
    "security",
    "xss-prevention",
    "declarative",
    "lightweight"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./widget": {
      "import": "./dist/widget/index.js",
      "types": "./dist/widget/index.d.ts"
    },
    "./fsm": {
      "import": "./dist/fsm/index.js",
      "types": "./dist/fsm/index.d.ts"
    },
    "./ui": {
      "import": "./dist/ui/index.js",
      "types": "./dist/ui/index.d.ts"
    },
    "./routing": {
      "import": "./dist/routing/index.js",
      "types": "./dist/routing/index.d.ts"
    },
    "./validation": {
      "import": "./dist/validation/index.js",
      "types": "./dist/validation/index.d.ts"
    },
    "./state": {
      "import": "./dist/state/index.js",
      "types": "./dist/state/index.d.ts"
    },
    "./security": {
      "import": "./dist/security/index.js",
      "types": "./dist/security/index.d.ts"
    },
    "./a11y": {
      "import": "./dist/a11y/index.js",
      "types": "./dist/a11y/index.d.ts"
    }
  },
  "bin": {
    "ux3": "./bin/ux3"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "predev": "./bin/clean-js && echo 'Skipping type-check for dev mode'",
    "prebuild": "./bin/clean-js",
    "pregold": "./bin/clean-js",
    "pretest": "./bin/clean-js",
    "pretype-check": "./bin/clean-js",
    "prelint": "./bin/clean-js",
    "prelint:tests": "./bin/clean-js",
    "clean:js": "./bin/clean-js",
    "check:clean-js": "./bin/clean-js --check",
    "dev": "./bin/ux3 dev",
    "dev:bg": "./bin/clean-js && sh -c \"tsc --watch & echo 'TypeScript watcher started'\"",
    "dev:iam": "./bin/ux3 dev examples/iam --port 1337 --mcp",
    "dev:kanban": "./bin/ux3 dev examples/kanban --port 1337 --mcp",
    "dev:onnx.cloud": "./bin/ux3 dev examples/onnx.cloud --port 1337 --mcp",
    "dev:quadra": "./bin/ux3 dev examples/quadra --port 1337 --mcp",
    "dev:kitchen.sink": "./bin/ux3 dev examples/kitchen.sink --port 1337 --mcp",
    "dev:tenant.saas": "./bin/ux3 dev examples/tenant.saas --port 1337 --mcp",
    "validate:iam": "npx tsx src/cli/validate.ts --projectDir ./examples/iam",
    "validate:kanban": "npx tsx src/cli/validate.ts --projectDir ./examples/kanban",
    "validate:onnx.cloud": "npx tsx src/cli/validate.ts --projectDir ./examples/onnx.cloud",
    "validate:quadra": "npx tsx src/cli/validate.ts --projectDir ./examples/quadra",
    "validate:kitchen.sink": "npx tsx src/cli/validate.ts --projectDir ./examples/kitchen.sink",
    "validate:tenant.saas": "npx tsx src/cli/validate.ts --projectDir ./examples/tenant.saas",
    "validate:strict:iam": "npx tsx src/cli/validate.ts --projectDir ./examples/iam --strict",
    "validate:strict:kanban": "npx tsx src/cli/validate.ts --projectDir ./examples/kanban --strict",
    "validate:strict:onnx.cloud": "npx tsx src/cli/validate.ts --projectDir ./examples/onnx.cloud --strict",
    "validate:strict:quadra": "npx tsx src/cli/validate.ts --projectDir ./examples/quadra --strict",
    "validate:strict:kitchen.sink": "npx tsx src/cli/validate.ts --projectDir ./examples/kitchen.sink --strict",
    "validate:strict:tenant.saas": "npx tsx src/cli/validate.ts --projectDir ./examples/tenant.saas --strict",
    "bundle": "esbuild src/index.ts src/ui/index.ts src/fsm/index.ts src/validation/index.ts src/state/index.ts src/security/index.ts src/a11y/index.ts --bundle --platform=browser --format=esm --minify --outdir=dist --out-extension:.js=.bundle.js --external:path --external:module --external:fs --external:fs/promises --external:http --external:os --external:url --external:fs-extra --external:glob --external:ajv --external:ajv-formats --external:esbuild --external:commander --external:yaml --external:zod --external:vitest && esbuild src/index.ts --bundle --platform=browser --format=esm --minify --outfile=dist/ux3.esm.js --external:path --external:module --external:fs --external:fs/promises --external:http --external:os --external:url --external:fs-extra --external:glob --external:ajv --external:ajv-formats --external:esbuild --external:commander --external:yaml --external:zod --external:vitest",
    "build": "npm run clean && tsc -b tsconfig.build.json && npm run bundle && npm run size-check",
    "gold": "npm run clean && tsc && vitest run && npm run size-check && npm run minify",
    "minify": "esbuild dist/**/*.js --minify --outdir=dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:html": "vite preview --outDir test-results/vitest/html",
    "test-plugins": "vitest run tests/plugin-*",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:kitchen.sink": "playwright test --config=playwright.kitchen-sink.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "tests": "npm run test && npm run test:e2e",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report test-results/playwright/html",
    "test:components": "vitest run tests/ui/widget/primitives.test.ts tests/examples/kitchen-sink-fsm.test.ts tests/examples/kitchen-sink-events.test.ts",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx",
    "lint:tests": "eslint tests --ext .ts,.tsx,.js,.jsx",
    "lint:iam": "npx tsx scripts/lint-iam.ts",
    "type-check": "tsc --project tsconfig.check.json",
    "clean": "./bin/clean-js && rm -rf dist packages/@ux3/*/dist tmp/tsc",
    "size-check": "if [ -d dist ]; then SIZE_MB=$(du -sm dist | cut -f1); echo \"dist size: ${SIZE_MB}MB\"; if [ \"$SIZE_MB\" -le 10 ]; then echo 'Bundle size OK (<= 10MB)'; else echo 'Bundle size check failed (> 10MB)'; exit 1; fi; else echo 'dist not emitted'; exit 1; fi",
    "security-audit": "npm audit --production",
    "a11y-audit": "node scripts/a11y-audit.js",
    "example": "node scripts/run-example.mjs",
    "publish": "npm publish --access public",
    "bundle:iam": "esbuild ./examples/iam/index.ts --bundle --platform=browser --format=esm --external:@ux3/* --external:../src/plugins/* --outfile=examples/iam/dist/app.bundle.js --sourcemap --minify"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.40.0",
    "@types/chai": "^5.2.3",
    "@types/fs-extra": "^11.0.4",
    "@types/marked": "^5.0.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.5.0",
    "chokidar": "^5.0.0",
    "commander": "^11.1.0",
    "cssnano": "^8.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.54.0",
    "fs-extra": "^11.3.3",
    "glob": "^13.0.1",
    "gray-matter": "^4.0.3",
    "jsdom": "^28.0.0",
    "marked": "^5.1.1",
    "mocha": "^11.3.0",
    "postcss": "^8.5.14",
    "rollup": "^4.24.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4",
    "yaml": "^2.8.2"
  },
  "overrides": {
    "serialize-javascript": "^7.0.2",
    "minimatch": "^9.0.7",
    "rollup": "^4.24.0",
    "esbuild": "^0.27.3"
  }
}
